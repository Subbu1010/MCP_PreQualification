# MCP references: search_mortgage_policy, explain_eligibility_decision
# Purpose: Sample environment variables for embeddings / LLM (optional). Copy to `.env` for local use.

# --- Google embeddings (optional; hash fallback used when unset) ---
GOOGLE_API_KEY=
GOOGLE_EMBEDDING_MODEL=text-embedding-004

# --- Vertex / Gemini (optional; mock narrative used when unset) ---
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash-001

# --- App ---
MCP_LOG_LEVEL=INFO
